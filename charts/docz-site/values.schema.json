{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "docz-site Helm chart values",
  "description": "Guardrail schema for the docz-site chart. Constrains the handful of values that break the deployment when wrong (listen port, proxy target, service type) at helm install/upgrade/template time. Permissive elsewhere (additionalProperties) — it does not police the whole value surface.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "port": { "type": "integer" },
        "doczApiUrl": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "description": "Kubernetes Service type.",
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        },
        "port": { "type": "integer" }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
