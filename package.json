{
  "name": "rfc-site",
  "version": "0.0.0",
  "description": "SSR web frontend for the rfc-api Markdown portal. See docs/rfc/0001 + docs/design/0003 + docs/impl/0005.",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "react-router dev",
    "dev:msw": "API_MODE=msw VITE_API_MODE=msw react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typegen": "react-router typegen",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^10.4.0",
    "@react-router/dev": "^7.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "ajv": "^8.20.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "msw": "^2.13.6",
    "orval": "^8.9.0",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.0.10",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@shikijs/rehype": "^4.0.2",
    "@tanstack/react-query": "^5.100.5",
    "clsx": "^2.1.1",
    "isbot": "^5",
    "mermaid": "^11.14.0",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.9.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
